---
import Layout from '../layouts/Layout.astro';
---

<Layout title="What We Carry" activePage="products">
  <!-- PAGE HEADER -->
  <div class="page-header">
    <p class="section-label">What We Carry</p>
    <h1>Your South Asian <em>Pantry</em></h1>
    <p class="subtitle">From ready-to-eat hot food to the specialty ingredients that make your cooking unforgettable.</p>
  </div>

<!-- Delivery Strip -->
<div class="delivery-strip">
  <div class="delivery-strip-inner">
    <p class="delivery-text"><strong>Shop from home.</strong> Order from our select grocery selection for delivery.</p>
    <div class="delivery-buttons">
      <a href="https://www.ubereats.com/store/international-groceries-4203-walnut-st/Qt-hin37VFSER2nNLpXjMw" target="_blank" rel="noopener noreferrer" class="delivery-btn uber">
        <span class="uber-dot"></span> Uber Eats
      </a>
      <a href="https://postmates.com/store/international-groceries-4203-walnut-st/Qt-hin37VFSER2nNLpXjMw" target="_blank" rel="noopener noreferrer" class="delivery-btn postmates">
        <span class="postmates-icon">⊕</span> Postmates
      </a>
    </div>
  </div>
</div>

  <!-- ============================== -->
  <!-- HOT FOOD BAR -->
  <!-- ============================== -->
  <section class="hotbar">
    <div class="hotbar-inner">
      <div class="hotbar-text">
        <p class="section-label light">Fresh Daily · Ready to Eat</p>
        <h2>The Hot Food <em>Counter</em></h2>
        <p>Our front counter is where the magic happens. Everything made fresh in-house — from our famous samosas to full curry plates ready to grab and go. This is what people drive across the city for.</p>

        <div class="hotbar-menu">
          <div class="hotbar-menu-group">
            <h3>Snacks & Sides</h3>
            <div class="hotbar-items">
              <span class="hotbar-item">Vegetable Samosas</span>
              <span class="hotbar-item">Tofu Samosas</span>
              <span class="hotbar-item">Vegetable Pakoras</span>
              <span class="hotbar-item">Rotis Made to Order</span>
              <span class="hotbar-item">Plain Paratha Made to Order</span>
              <span class="hotbar-item">Aloo Paratha Made to Order</span>


            </div>
          </div>
          <div class="hotbar-menu-group">
            <h3>Fresh Hot Foods</h3>
            <div class="hotbar-items">
              <span class="hotbar-item">Palak Paneer</span>
              <span class="hotbar-item">Chana Masala</span>
              <span class="hotbar-item">Goat Curry</span>
              <span class="hotbar-item">Chicken Curry</span>
              <span class="hotbar-item">Chicken Tikka</span>
              <span class="hotbar-item">Mix Vegetables</span>
              <span class="hotbar-item">Punjabi Khari</span>
              <span class="hotbar-item">Dal</span>
              <span class="hotbar-item">Eggplant</span>
              <span class="hotbar-item">Chicken Kebab</span>
              <span class="hotbar-item">Rice</span>
            </div>
            <p class="rotating-note">Selection varies daily based on availability</p>
          </div>
          <div class="hotbar-menu-group">
            <h3>Fresh Chutneys</h3>
            <div class="hotbar-items">
              <span class="hotbar-item">Fresh Green Chutney</span>
              <span class="hotbar-item">Tamarind Chutney</span>
            </div>
          </div>
        </div>
      </div>
      <div class="hotbar-right">
        <div class="hotbar-photo">
          <img src="/images/products/hotbar.jpeg" alt="Variety of fresh hot food available to-go at International Foods & Spices"/>
        </div>
        <a href="/hot-food-menu.pdf" target="_blank" class="hotbar-menu-btn">View Full Menu & Prices →</a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- GROCERY CAROUSEL -->
  <!-- ============================== -->
  <section class="grocery-section" id="grocery">
    <div class="grocery-header">
      <p class="section-label">Take It Home</p>
      <h2>Stock Your Kitchen</h2>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn prev" id="prevBtn" aria-label="Scroll left">&#8592;</button>
      <div class="carousel" id="carousel">

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/masala.jpg" alt="Spices and masalas" />
          </div>
          <div class="card-body">
            <h3>Spices & Masalas</h3>
            <p>Whole and ground spices, masala blends, curry powders — the hard-to-find stuff that makes the difference.</p>
            <div class="card-tags">
              <span>Whole Spices</span>
              <span>Ground Powders</span>
              <span>Masala Blends</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/rice.jpg" alt="Rice and flour" />
          </div>
          <div class="card-body">
            <h3>Rice & Flour</h3>
            <p>Premium basmati rice, atta flour, and specialty grains in bulk. The brands your family trusts.</p>
            <div class="card-tags">
              <span>Basmati Rice</span>
              <span>Atta Flour</span>
              <span>Teff Flour</span>
              <span>Bulk Bags</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/meats.jpg" alt="Halal meats" />
          </div>
          <div class="card-body">
            <h3>Halal Meats</h3>
            <p>Boneless chicken, chicken legs, whole chicken, and goat meat — all halal, cleaned and cut in-house, kept frozen fresh.</p>
            <div class="card-tags">
              <span>Boneless Chicken</span>
              <span>Goat Meat</span>
              <span>Halal</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/breads.jpg" alt="Injera and flatbreads" />
          </div>
          <div class="card-body">
            <h3>Injera & Breads</h3>
            <p>Fresh Ethiopian injera, frozen roti, naan, and pita — ready for your table without the trouble.</p>
            <div class="card-tags">
              <span>Injera</span>
              <span>Roti</span>
              <span>Naan</span>
              <span>Pita</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/produce.jpg" alt="Fresh produce" />
          </div>
          <div class="card-body">
            <h3>Fresh Produce</h3>
            <p>Fresh vegetables, fruits, herbs, and specialty South Asian produce you won't find at the chain stores.</p>
            <div class="card-tags">
              <span>Vegetables</span>
              <span>Herbs</span>
              <span>Specialty</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/frozenfood.jpg" alt="Frozen foods" />
          </div>
          <div class="card-body">
            <h3>Frozen & Pantry</h3>
            <p>Frozen meals, chutneys, pickles, sauces, dosa batters, falooda ice cream — your whole kitchen, stocked.</p>
            <div class="card-tags">
              <span>Frozen Meals</span>
              <span>Chutneys</span>
              <span>Pickles</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/sweets.jpg" alt="Indian sweets and baklava" />
          </div>
          <div class="card-body">
            <h3>Sweets & Baklava</h3>
            <p>Gulab jamun, jalebi, fresh baklava, and more — for celebrations or everyday indulgence.</p>
            <div class="card-tags">
              <span>Gulab Jamun</span>
              <span>Jalebi</span>
              <span>Barfi</span>
              <span>Kaju Katli</span>
              <span>Kaju roll</span>
              <span>Ladoo</span>
              <span>Dry mix sweets</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/chai.jpg" alt="Assortment of Indian coffees, teas, and chai blends"/>
          </div>
          <div class="card-body">
            <h3>Tea & Coffee</h3>
            <p>Chai blends, loose leaf teas, and coffee from brands you know and love.</p>
            <div class="card-tags">
              <span>Chai</span>
              <span>Loose Leaf</span>
              <span>Coffee</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/kulfi.jpg" alt="Assortment of kulfi, falooda, and South Asian ice cream brands"/>
          </div>
          <div class="card-body">
            <h3>Ice Cream</h3>
            <p>Falooda, kulfi, mango, and other South Asian ice cream flavors you won't find anywhere else.</p>
            <div class="card-tags">
              <span>Falooda</span>
              <span>Kulfi</span>
              <span>Mango</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/dairy.jpg" alt="Assortment of milk, eggs, butter, and more dairy products"/>
          </div>
          <div class="card-body">
            <h3>Dairy & Essentials</h3>
            <p>Milk, eggs, butter, ghee, and other everyday essentials so you can do all your shopping in one stop.</p>
            <div class="card-tags">
              <span>Milk</span>
              <span>Eggs</span>
              <span>Butter</span>
              <span>Ghee</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/nuts.jpg" alt="Assortment of freshly packaged almonds, pistachios, and more"/>
          </div>
          <div class="card-body">
            <h3>Nuts & Dry Fruits</h3>
            <p>Freshly packaged almonds, cashews, pistachios, and more — perfect for snacking, cooking, or gifting.</p>
            <div class="card-tags">
              <span>Almonds</span>
              <span>Cashews</span>
              <span>Pistachios</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/appliances.jpg" alt="Assortment of kitchen appliances and cookware"/>
          </div>
          <div class="card-body">
            <h3>Appliances</h3>
            <p>Kitchen appliances and cookware for South Asian cooking — the tools your kitchen needs.</p>
            <div class="card-tags">
              <span>Wok</span>
              <span>Microwave</span>
              <span>Molacjete</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/henna.jpg" alt="Assortment of Indian beauty products, including shampoo, hair oil, henna, and more"/>
          </div>
          <div class="card-body">
            <h3>Incense & Beauty</h3>
            <p>Incense sticks, henna, shampoo, toothpaste, and personal care essentials from trusted brands.</p>
            <div class="card-tags">
              <span>Incense</span>
              <span>Henna</span>
              <span>Indian Shampoo & Conditioner</span>
              <span>Indian Hair Oil</span>
              <span>Toothpaste</span>
            </div>
          </div>
        </div>

        <div class="grocery-card">
          <div class="card-img">
            <img src="/images/products/diwali.jpg" alt="Assortment of items for Holi, Ramadan, Diwali, and more"/>
          </div>
          <div class="card-body">
            <h3>Seasonal & Holiday</h3>
            <p>Special items for Holi, Ramadan, Diwali, and other celebrations — stocked when the season calls for it.</p>
            <div class="card-tags">
              <span>Holi</span>
              <span>Ramadan</span>
              <span>Diwali</span>
            </div>
          </div>
        </div>

      </div>
      <button class="carousel-btn next" id="nextBtn" aria-label="Scroll right">&#8594;</button>
    </div>
  </section>

  <!-- BRANDS NOTE -->
  <section class="brands-note">
    <p class="section-label">Brands You Trust</p>
    <h2>We Carry What You Know</h2>
    <p>We stock the brands you grew up with and the ones your recipes call for. If you can't find what you're looking for, just ask — we're happy to help you track it down.</p>
    <a href="/visit#contact" class="cta-link">Can't find something? Contact us →</a>  </section>
</Layout>

<script>
  const carousel = document.getElementById('carousel');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  const scrollAmount = 340;

  prevBtn?.addEventListener('click', () => {
    carousel?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });

  nextBtn?.addEventListener('click', () => {
    carousel?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });
</script>

<style>
  
.hotbar-menu-btn {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  background-color: #C23616;
  color: #FDF6EC;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  border-radius: 4px;
  text-align: center;
  transition: background-color 0.2s ease;
}

.hotbar-menu-btn:hover {
  background-color: #A02D13;
}
  
  /* Delivery Section at Top */
  .delivery-strip {
  padding: 0 1.5rem;
  margin-top: -1rem;
  margin-bottom: 2.5rem;
}

.delivery-strip-inner {
  max-width: none;
  margin: 0 auto;
  background: #2D5016;
  border-radius: 0.5rem;
  padding: 1.25rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}

.delivery-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.85);
  margin: 0;
  line-height: 1.4;
}

.delivery-text strong {
  color: #fff;
  font-weight: 700;
}

.delivery-buttons {
  display: flex;
  gap: 0.75rem;
  flex-shrink: 0;
}

.delivery-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.65rem 1.4rem;
  border-radius: 0.35rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.delivery-btn:hover {
  opacity: 0.9;
}

.delivery-btn.uber {
  background: #fff;
  color: #1a1a1a;
}

.uber-dot {
  width: 10px;
  height: 10px;
  background: #1a1a1a;
  border-radius: 50%;
  display: inline-block;
}

.delivery-btn.postmates {
  background: #FF5F00;
  color: #fff;
}

.postmates-icon {
  font-size: 1.1rem;
  font-weight: 700;
}

  /* ============================== */
  /* HOT BAR */
  /* ============================== */

  .rotating-note {
  font-size: 0.78rem;
  color: rgba(253, 246, 236, 0.4);
  font-style: italic;
  margin-top: 0.6rem;
}

  .hotbar {
    background: var(--dark);
    color: var(--cream);
    padding: 5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hotbar::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(194, 54, 22, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 30%, rgba(232, 168, 56, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hotbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
  }

  .hotbar-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.2rem;
  }

  .hotbar-text h2 em {
    font-style: italic;
    color: var(--saffron);
  }

  .hotbar-text > p {
    font-size: 1.02rem;
    line-height: 1.8;
    color: rgba(253, 246, 236, 0.6);
    margin-bottom: 0.8rem;
    max-width: 480px;
  }

  .hotbar-menu {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hotbar-menu-group h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(253, 246, 236, 0.8);
    margin-bottom: 0.8rem;
    padding-top: 0.5rem;
  }

  .hotbar-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hotbar-item {
    padding: 0.5rem 1rem;
    border: 1px solid rgba(232, 168, 56, 0.3);
    border-radius: 2rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--saffron);
    letter-spacing: 0.02em;
  }

  .hotbar-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  align-self: center;
  }

  .hotbar-photo {
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .hotbar-photo img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.5rem;
  }

  /* ============================== */
  /* GROCERY CAROUSEL */
  /* ============================== */
  .grocery-section {
    padding: 5rem 0 0rem;
    scroll-margin-top: 5rem;
  }

  .grocery-header {
    text-align: center;
    padding: 0 3rem;
    margin-bottom: 3rem;
  }

  .grocery-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--dark);
    letter-spacing: -0.02em;
  }

  .carousel-wrapper {
    position: relative;
    padding: 0 3rem;
  }

  .carousel {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 1rem 0 2rem;
    scrollbar-width: none;
  }

  .carousel::-webkit-scrollbar {
    display: none;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border-light);
    background: var(--cream);
    color: var(--dark);
    font-size: 1.1rem;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
  }

  .carousel-btn:hover {
    background: var(--dark);
    color: var(--cream);
    border-color: var(--dark);
  }

  .carousel-btn.prev { left: 0.5rem; }
  .carousel-btn.next { right: 0.5rem; }

  .grocery-card {
    flex: 0 0 300px;
    scroll-snap-align: start;
    background: var(--warm-white);
    border: 1px solid var(--border-light);
    border-radius: 0.75rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.35s ease;
    display: flex;
    flex-direction: column;
  }

  .grocery-card:hover {
    border-color: var(--saffron);
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(26, 18, 8, 0.1);
  }

  .card-img {
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .grocery-card:hover .card-img img {
    transform: scale(1.05);
  }

  .card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }

  .card-body p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: 1rem;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-tags span {
    padding: 0.3rem 0.7rem;
    background: var(--cream);
    border: 1px solid var(--border-light);
    border-radius: 2rem;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-body);
    letter-spacing: 0.02em;
  }

  /* ============================== */
  /* BRANDS NOTE */
  /* ============================== */
  .brands-note {
    padding: 2rem 3rem 3rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .brands-note h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 900;
    color: var(--dark);
    margin-bottom: 1rem;
  }

  .brands-note p {
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--chili);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 0.3s;
  }

  .cta-link:hover { opacity: 0.7; }

  /* ============================== */
  /* RESPONSIVE */
  /* ============================== */
  @media (max-width: 768px) {
    .hotbar { padding: 4rem 1.5rem; }
    .hotbar-inner { grid-template-columns: 1fr; }
    .grocery-section { padding: 4rem 0 3rem; }
    .grocery-header { padding: 0 1.5rem; }
    .carousel-wrapper { padding: 0 1.5rem; }
    .carousel-btn { display: none; }
    .grocery-card { flex: 0 0 260px; }
    .brands-note { padding: 2rem 1.5rem 3rem; }

    .delivery-strip {
    padding: 0 1rem;
    margin-top: 0.75rem;
    margin-bottom: 2rem;
  }

    .delivery-strip-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.25rem 1.5rem;
      gap: 1rem;
    }

    .delivery-buttons {
      width: 100%;
    }

    .delivery-btn {
      flex: 1;
      justify-content: center;
      padding: 0.6rem 1rem;
      font-size: 0.82rem;
    }
  }
</style>