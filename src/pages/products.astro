---
import Layout from '../layouts/Layout.astro';
---

<Layout title="What We Carry" activePage="products">
  <!-- PAGE HEADER -->
  <div class="page-header">
    <p class="section-label">What We Carry</p>
    <h1>Your South Asian <em>Pantry</em></h1>
    <p class="subtitle">From everyday staples to the specialty ingredients that make your cooking unforgettable.</p>
  </div>

  <!-- CATEGORY NAV -->
  <div class="category-nav">
    <a href="#spices" class="category-nav-item">🌶️ Spices & Masalas</a>
    <a href="#rice" class="category-nav-item">🍚 Rice & Flour</a>
    <a href="#meats" class="category-nav-item">🥩 Halal Meats</a>
    <a href="#breads" class="category-nav-item">🫓 Injera & Breads</a>
    <a href="#produce" class="category-nav-item">🥬 Fresh Produce</a>
    <a href="#hotbar" class="category-nav-item">🔥 Hot Food Bar</a>
    <a href="#frozen" class="category-nav-item">❄️ Frozen & Pantry</a>
    <a href="#sweets" class="category-nav-item">🍬 Sweets & Baklava</a>
  </div>

  <div class="divider"><div class="divider-line"><span>Shop With Us</span></div></div>

  <!-- SPICES & MASALAS -->
  <section class="category-section" id="spices">
    <div class="category-row">
      <div class="category-photo">
        <img src="/images/products/masala.jpg" alt="Spices and masalas at International Foods & Spices" />
      </div>
      <div class="category-text">
        <p class="section-label">Aisle Spotlight</p>
        <h2>Spices & Masalas</h2>
        <p>Our spice wall is the heart of the store. Whole seeds, ground powders, specialty blends — we carry the range that serious cooks need, at prices that beat the supermarket by a mile.</p>
        <p>From turmeric and cumin to chaat masala and hing, if your recipe calls for it, we've got it.</p>
        <div class="category-tags">
          <span class="tag">Whole Spices</span>
          <span class="tag">Ground Powders</span>
          <span class="tag">Masala Blends</span>
          <span class="tag">Curry Powders</span>
          <span class="tag">Chili Varieties</span>
        </div>
      </div>
    </div>
  </section>

  <div class="category-divider"><hr></div>

  <!-- RICE & FLOUR -->
  <section class="category-section" id="rice">
    <div class="category-row reverse">
      <div class="category-photo">
        <img src="/images/products/rice.jpg" alt="Rices and flour at International Foods & Spices" />
      </div>
      <div class="category-text">
        <p class="section-label">Pantry Essentials</p>
        <h2>Rice & Flour</h2>
        <p>We stock the premium basmati rice brands your family already knows — in bulk bags so you don't have to shop every week. Atta flour, besan, rice flour, and more for your rotis, dosas, and everything in between.</p>
        <div class="category-tags">
          <span class="tag">Basmati Rice</span>
          <span class="tag">Atta Flour</span>
          <span class="tag">Besan</span>
          <span class="tag">Rice Flour</span>
          <span class="tag">Couscous</span>
          <span class="tag">Bulk Bags</span>
        </div>
      </div>
    </div>
  </section>

  <div class="category-divider"><hr></div>

  <!-- HALAL MEATS -->
  <section class="category-section" id="meats">
    <div class="category-row">
      <div class="category-photo">
        <img src="/images/products/meats.jpg" alt="Variety of halal meats at International Foods & Spices" />
      </div>
      <div class="category-text">
        <p class="section-label">Halal</p>
        <h2>Halal Meats</h2>
        <p>All halal, all cleaned and cut in-house, and kept frozen fresh. We bring it in fresh, handle the prep ourselves, and freeze it so it's ready when you are.</p>
        <div class="category-tags">
          <span class="tag">Boneless Chicken</span>
          <span class="tag">Chicken Legs</span>
          <span class="tag">Whole Chicken</span>
          <span class="tag">Goat Meat</span>
          <span class="tag">Halal</span>
        </div>
      </div>
    </div>
  </section>

  <div class="category-divider"><hr></div>

  <!-- BREADS -->
  <section class="category-section" id="breads">
    <div class="category-row reverse">
      <div class="category-photo">
        <img src="/images/products/breads.jpg" alt="Variety of injera and Indian flatbreads at International Foods & Spices" />
      </div>
      <div class="category-text">
        <p class="section-label">Breads</p>
        <h2>Injera & Flatbreads</h2>
        <p>Fresh Ethiopian injera, frozen roti, naan, and pita at half the price of the chain supermarket. Ready for your table without the trouble of making it from scratch.</p>
        <div class="category-tags">
          <span class="tag">Injera</span>
          <span class="tag">Roti</span>
          <span class="tag">Naan</span>
          <span class="tag">Pita</span>
        </div>
      </div>
    </div>
  </section>

  <div class="category-divider"><hr></div>

  <!-- PRODUCE -->
  <section class="category-section" id="produce">
    <div class="category-row">
      <div class="category-photo">
        <img src="/images/products/produce.jpg" alt="Variety of fresh produce at International Foods & Spices" />
      </div>
      <div class="category-text">
        <p class="section-label">Fresh</p>
        <h2>Fresh Produce</h2>
        <p>Fresh vegetables, fruits, herbs, and specialty South Asian produce that the chain stores don't carry. The ingredients that make your home cooking taste like home.</p>
        <div class="category-tags">
          <span class="tag">Fresh Vegetables</span>
          <span class="tag">Fresh Fruit</span>
          <span class="tag">Herbs</span>
          <span class="tag">Specialty Produce</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOT BAR CALLOUT -->
  <section class="hotbar-callout" id="hotbar">
    <div class="hotbar-inner">
      <div class="hotbar-text">
        <p class="section-label light">Fresh Daily</p>
        <h2>The Hot Food <em>Counter</em></h2>
        <p>Our front counter is where the magic happens. Everything made fresh in-house — from our famous samosas to full curry plates ready to grab and go. This is what people drive across the city for.</p>

        <div class="hotbar-menu">
          <div class="hotbar-menu-group">
            <h3>Snacks & Sides</h3>
            <div class="hotbar-items">
              <span class="hotbar-item">Vegetable Samosas</span>
              <span class="hotbar-item">Tofu Samosas</span>
              <span class="hotbar-item">Vegetable Fritters</span>
              <span class="hotbar-item">Rotis Made to Order</span>
            </div>
          </div>
          <div class="hotbar-menu-group">
            <h3>Fresh Hot Foods</h3>
            <div class="hotbar-items">
              <span class="hotbar-item">Goat Curry</span>
              <span class="hotbar-item">Chicken Curry</span>
              <span class="hotbar-item">Chana</span>
              <span class="hotbar-item">Rice</span>
              <span class="hotbar-item">Eggplant Dishes</span>
            </div>
          </div>
          <div class="hotbar-menu-group">
            <h3>Chutneys</h3>
            <div class="hotbar-items">
              <span class="hotbar-item">Fresh Green Chutney</span>
              <span class="hotbar-item">Tamarind Chutney</span>
            </div>
          </div>
        </div>
      </div>
      <div class="hotbar-photo">
        <img src="/images/products/hotbar.jpeg" alt="Variety of fresh hotbar available to-go at International Foods & Spices"/>
      </div>
    </div>
  </section>

  <!-- FROZEN & PANTRY -->
  <section class="category-section" id="frozen">
    <div class="category-row reverse">
      <div class="category-photo">
        <img src="/images/products/frozenfood.jpg" alt="Variety of Frozen Food available at International Foods & Spices" />
      </div>
      <div class="category-text">
        <p class="section-label">Stock Up</p>
        <h2>Frozen & Pantry Goods</h2>
        <p>Frozen meals, frozen samosas for home, chutneys, pickles, garlic and ginger pastes, sauces, dosa and idli batters, and falooda ice cream. Everything you need to keep your kitchen fully loaded.</p>
        <div class="category-tags">
          <span class="tag">Frozen Meals</span>
          <span class="tag">Chutneys</span>
          <span class="tag">Pickles</span>
          <span class="tag">Sauces</span>
          <span class="tag">Ice Cream</span>
          <span class="tag">Batters</span>
        </div>
      </div>
    </div>
  </section>

  <div class="category-divider"><hr></div>

<!-- SWEETS -->
<section class="category-section" id="sweets">
  <div class="category-row">
    <div class="category-photo">
      <img src="/images/products/sweets.jpg" alt="Variety of Indian Sweets & Baklava available at International Foods & Spices" />
    </div>
    <div class="category-text">
      <p class="section-label">Sweet Tooth</p>
      <h2>Indian Sweets & Baklava</h2>
      <p>Traditional Indian sweets and fresh baklava — perfect for celebrations, gifts, or just treating yourself after a long day.</p>
      <div class="category-tags">
        <span class="tag">Gulab Jamun</span>
        <span class="tag">Jalebi</span>
        <span class="tag">Barfi</span>
        <span class="tag">Baklava</span>
      </div>
    </div>
  </div>
</section>

  <!-- BRANDS NOTE -->
  <section class="brands-note">
    <p class="section-label">Brands You Trust</p>
    <h2>We Carry What You Know</h2>
    <p>We stock the brands you grew up with and the ones your recipes call for. If you can't find what you're looking for, just ask — we're happy to help you track it down or order it in.</p>
    <a href="/visit" class="cta-link">Can't find something? Contact us →</a>
  </section>
</Layout>

<style>

    .category-photo img,
    .hotbar-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
    }

  /* CATEGORY NAV */
  .category-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0 3rem 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .category-nav-item {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background: var(--warm-white);
    border: 1px solid var(--border-light);
    border-radius: 2rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-body);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: all 0.3s;
    white-space: nowrap;
  }

  .category-nav-item:hover {
    border-color: var(--saffron);
    background: var(--cream);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(26, 18, 8, 0.06);
  }

  /* CATEGORY SECTIONS */
  .category-section {
    padding: 5rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
    scroll-margin-top: 5rem;
  }

  .category-row {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .category-row.reverse { direction: rtl; }
  .category-row.reverse > * { direction: ltr; }

  .category-photo {
    aspect-ratio: 4/3;
    background: var(--border-light);
    border-radius: 0.5rem;
  }

  .category-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--dark);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .category-text p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
  }

  .category-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }

  .tag {
    padding: 0.4rem 0.9rem;
    background: var(--warm-white);
    border: 1px solid var(--border-light);
    border-radius: 2rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-body);
    letter-spacing: 0.02em;
  }

  .category-divider {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .category-divider hr {
    border: none;
    height: 1px;
    background: var(--border-light);
  }

  /* HOT BAR */
  .hotbar-callout {
    background: var(--dark);
    color: var(--cream);
    padding: 5rem 3rem;
    position: relative;
    overflow: hidden;
    scroll-margin-top: 5rem;
  }

  .hotbar-callout::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(194, 54, 22, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 30%, rgba(232, 168, 56, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hotbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
  }

  .hotbar-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.2rem;
  }

  .hotbar-text h2 em {
    font-style: italic;
    color: var(--saffron);
  }

  .hotbar-text > p {
    font-size: 1.02rem;
    line-height: 1.8;
    color: rgba(253, 246, 236, 0.6);
    margin-bottom: 0.8rem;
    max-width: 480px;
  }

  .hotbar-menu {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hotbar-menu-group h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(253, 246, 236, 0.8);
    margin-bottom: 0.8rem;
    padding-top: 0.5rem;
  }

  .hotbar-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hotbar-item {
    padding: 0.5rem 1rem;
    border: 1px solid rgba(232, 168, 56, 0.3);
    border-radius: 2rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--saffron);
    letter-spacing: 0.02em;
  }

  .hotbar-photo {
    aspect-ratio: 1;
    background: var(--dark-warm);
    border-radius: 0.5rem;
    border: 1px solid rgba(255,255,255,0.06);
  }

  /* BRANDS NOTE */
  .brands-note {
    padding: 2rem 3rem 3rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .brands-note h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 900;
    color: var(--dark);
    margin-bottom: 1rem;
  }

  .brands-note p {
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--chili);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 0.3s;
  }

  .cta-link:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .category-nav { padding: 0 1.5rem 2rem; }
    .category-row,
    .category-row.reverse { grid-template-columns: 1fr; direction: ltr; }
    .category-section { padding: 3rem 1.5rem; }
    .category-divider { padding: 0 1.5rem; }
    .hotbar-inner { grid-template-columns: 1fr; }
    .hotbar-callout { padding: 4rem 1.5rem; }
    .brands-note { padding: 3rem 1.5rem; }
  }
</style>