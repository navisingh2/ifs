---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Catering" activePage="catering">
  <!-- PAGE HEADER -->
  <div class="page-header">
    <p class="section-label">Catering & Bulk Orders</p>
    <h1>Feeding a <em>Crowd?</em></h1>
    <p class="subtitle">From family gatherings to campus events, we'll handle the food so you can focus on the occasion. All catering orders are available for pickup only.</p>
  </div>

  <!-- INTRO -->
  <section class="catering-intro">
    <div class="catering-intro-grid">
      <div class="catering-intro-text">
        <h2>Made Fresh, Served in Bulk</h2>
        <p>Whether you need 50 samosas for a birthday party or trays of curry for a campus event, we've got you covered. <strong>Everything is made fresh</strong> in our kitchen — the same quality you get at our counter, scaled up for your occasion.</p>
        <p>We've been feeding University City for over 35 years. Let us help you feed your guests.</p>
      </div>
      <div class="catering-photo">
        <img src="/images/catering.jpg" alt="Catering spread photo"/>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE OFFER -->
  <section class="catering-offerings">
    <div class="offerings-inner">
      <div class="offerings-header">
        <p class="section-label light">Our Catering Menu</p>
        <h2>What We Offer</h2>
        <p>Popular items for bulk and catering orders</p>
      </div>
      <div class="offerings-grid">
        <div class="offering-card">
          <span class="icon">🥟</span>
          <h3>Samosa Platters</h3>
          <p>Our famous samosas in bulk — vegetable and tofu varieties. Served with house-made green and tamarind chutneys.</p>
        </div>
        <div class="offering-card">
          <span class="icon">🍛</span>
          <h3>Curry Trays</h3>
          <p>Goat curry, chicken curry, chana, eggplant dishes — full trays of our hot bar favorites, ready to serve.</p>
        </div>
        <div class="offering-card">
          <span class="icon">🫓</span>
          <h3>Roti & Sides</h3>
          <p>Fresh rotis, rice, vegetable fritters, and chutneys to round out your spread.</p>
        </div>
        <div class="offering-card">
          <span class="icon">🧺</span>
          <h3>Custom Orders</h3>
          <p>Have something specific in mind? Call us and we'll work with you to put together exactly what you need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works">
    <div class="how-header">
      <p class="section-label">How It Works</p>
      <h2>Three Simple Steps</h2>
    </div>
    <div class="how-steps">
      <div class="how-step">
        <div class="step-number">1</div>
        <h3>Call Us</h3>
        <p>Give us a call at (215) 222-4480 and let us know what you're planning — event size, date, and what you'd like.</p>
      </div>
      <div class="how-step">
        <div class="step-number">2</div>
        <h3>We Prepare</h3>
        <p>We'll put your order together fresh. No frozen reheats — everything is made in our kitchen for your event.</p>
      </div>
      <div class="how-step">
        <div class="step-number">3</div>
        <h3>Pick Up & Enjoy</h3>
        <p>Swing by the store to pick up your order, ready to serve. Hot, fresh, and made with care.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="catering-cta-block">
    <div class="cta-box">
      <h2>Ready to Place an Order?</h2>
      <p>Call us to discuss your event or send us a message through our contact page.</p>
      <div class="btn-row">
        <a href="tel:2152224480" class="btn btn-primary">Call (215) 222-4480</a>
        <a href="/visit#contact" class="btn btn-secondary">Send a Message →</a>      </div>
    </div>
  </section>
</Layout>

<style>
  /* Mobile Vieew */
  @media (max-width: 768px) {
  .catering-intro { padding: 3rem 1.5rem; }
  .catering-intro-grid { grid-template-columns: 1fr; gap: 2rem; }
  .catering-offerings { padding: 4rem 1.5rem; }
  .offerings-grid {
    gap: 1rem;
    overflow-x: auto;
  }
  .offering-card {
    min-width: 220px;
    flex: 0 0 220px;
  }
  .how-it-works { padding: 4rem 1.5rem; }
  .how-steps { grid-template-columns: 1fr; gap: 2rem; }
  .catering-cta-block { padding: 0 1.5rem 4rem; }
  .cta-box { padding: 3rem 2rem; }
}

  /* INTRO */
  .catering-intro {
    padding: 2rem 3rem 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-header {
    padding-bottom: 2rem;
  }

  .catering-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .catering-intro-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--dark);
    letter-spacing: -0.02em;
    margin-bottom: 1.2rem;
    line-height: 1.1;
  }

  .catering-intro-text p {
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .catering-intro-text p strong {
    color: var(--text-body);
    font-weight: 600;
  }

  .catering-photo {
  aspect-ratio: 1;
  background: var(--border-light);
  border-radius: 0.5rem;
  overflow: hidden;
}

.catering-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 0.5rem;
}

  /* OFFERINGS */
  .catering-offerings {
    padding: 5rem 3rem;
    background: var(--dark);
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .catering-offerings::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 168, 56, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

.offerings-inner {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
}

  .offerings-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .offerings-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .offerings-header p {
    font-size: 1rem;
    color: rgba(253, 246, 236, 0.55);
    margin-top: 0.8rem;
  }

.offerings-grid {
  display: flex;
  gap: 1.5rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 1rem;
}

.offerings-grid::-webkit-scrollbar {
  height: 4px;
}

.offerings-grid::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.05);
  border-radius: 2px;
}

.offerings-grid::-webkit-scrollbar-thumb {
  background: rgba(232, 168, 56, 0.3);
  border-radius: 2px;
}

.offering-card {
  flex: 1;
  min-width: 0;
  scroll-snap-align: start;
  padding: 1.8rem 1.5rem;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 0.5rem;
  background: rgba(255,255,255,0.03);
  transition: border-color 0.3s;
}

  .offering-card:hover { border-color: var(--saffron); }

  .offering-card .icon {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    display: block;
  }

  .offering-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .offering-card p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(253, 246, 236, 0.55);
  }

  /* HOW IT WORKS */
  .how-it-works {
    padding: 5rem 3rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .how-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .how-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--dark);
    letter-spacing: -0.02em;
  }

  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .how-step {
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--chili);
    color: var(--cream);
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 1.2rem;
    margin-bottom: 1.2rem;
  }

  .how-step h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.6rem;
  }

  .how-step p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* CTA */
  .catering-cta-block {
    padding: 0 3rem 5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--chili) 0%, var(--chili-dark) 100%);
    border-radius: 1rem;
    padding: 4rem;
    text-align: center;
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .cta-box::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .cta-box h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 900;
    margin-bottom: 1rem;
    position: relative;
    letter-spacing: -0.02em;
  }

  .cta-box p {
    font-size: 1rem;
    opacity: 0.85;
    margin-bottom: 2rem;
    position: relative;
  }

  .btn-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    position: relative;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.8rem;
    border-radius: 0.4rem;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--cream);
    color: var(--chili);
  }

  .btn-secondary {
    background: transparent;
    color: var(--cream);
    border: 1px solid rgba(255,255,255,0.3);
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  @media (max-width: 768px) {
    .catering-intro { padding: 3rem 1.5rem; }
    .catering-intro-grid { grid-template-columns: 1fr; gap: 2rem; }
    .catering-offerings { padding: 4rem 1.5rem; }
    .offerings-grid { grid-template-columns: 1fr; }
    .how-it-works { padding: 4rem 1.5rem; }
    .how-steps { grid-template-columns: 1fr; gap: 2rem; }
    .catering-cta-block { padding: 0 1.5rem 4rem; }
    .cta-box { padding: 3rem 2rem; }
  }
</style>