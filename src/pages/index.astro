---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" activePage="home" showBanner={true}>

  <!-- HERO -->
  <section class="hero">
    <h1>Home to Philly's <em>Best</em> Samosas.</h1>
    <p class="hero-sub">A family-owned Indian & South Asian grocery in the heart of University City. Fresh spices, produce, hot food, and more — serving Philadelphia since 1987.</p>
    <a href="/visit" class="hero-cta">Visit Us →</a>
    <div class="hero-details">
      <div class="hero-detail-item">
        <span class="hero-detail-label">Location</span>
        <a href="https://maps.app.goo.gl/aNVmfQDGnJu19tgi7" target="_blank" rel="noopener noreferrer" class="hero-detail-value hero-detail-link">4203 Walnut St<br>Philadelphia, PA 19104</a>
      </div>
      <div class="hero-detail-item">
        <span class="hero-detail-label">Phone</span>
        <a href="tel:+12152224480" class="hero-detail-value hero-detail-link">(215) 222-4480</a>
      </div>
      <div class="hero-detail-item">
        <span class="hero-detail-label">Open Daily</span>
        <span class="hero-detail-value">10:30am – 8pm</span>
      </div>
      <div class="hero-detail-item">
        <span class="hero-detail-label">Closed</span>
        <span class="hero-detail-value">Tuesdays</span>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="intro-strip">
    <div class="intro-strip-item">
      <div class="number">35+</div>
      <div class="label">Years in University City</div>
    </div>
    <div class="intro-strip-item">
      <div class="number">1987</div>
      <div class="label">Family-Owned Since</div>
    </div>
    <div class="intro-strip-item">
      <div class="number">6</div>
      <div class="label">Days a Week</div>
    </div>
  </div>

  <!-- SAMOSA SPOTLIGHT -->
  <section class="samosa-spotlight">
    <div class="samosa-inner">
      <div class="samosa-content">
        <p class="section-label light">The Hot Bar</p>
        <h2>The Samosas That Made Us <em>Famous</em></h2>
        <p>Made fresh in-house every day — with a variety of vegetable or tofu samosas. Crispy, savory, and perfect on their own or with our house-made coriander chutney, available for purchase. Grab one on your way out.</p>
        <div class="samosa-quote">
          <p>"Delicious, house made at the front samosas for less than $2 each. Stop by and treat yourself!"</p>
          <cite>— Google Review</cite>
        </div>
      </div>
	<div class="samosa-photo">
		<img src="/images/samosa.jpeg" alt="Fresh homemade samosas at International Foods & Spices" />
	</div>
    </div>
  </section>

  <!-- PRODUCT PREVIEW -->
  <section class="products-preview">
    <div class="section-header">
      <div>
        <p class="section-label">What We Carry</p>
        <h2>Your South Asian Pantry</h2>
      </div>
      <a href="/products" class="see-all">See Everything →</a>
    </div>
    <div class="product-grid">
      <a class="product-card" href="/products#grocery">
        <span class="product-icon">🌶️</span>
        <h3>Spices & Masalas</h3>
        <p>Whole and ground spices, masala blends, curry powders — the hard-to-find stuff that makes the difference.</p>
      </a>
      <a class="product-card" href="/products#grocery">
        <span class="product-icon">🍚</span>
        <h3>Rice & Flour</h3>
        <p>Premium basmati rice, atta flour, and specialty grains in bulk. The brands your family trusts.</p>
      </a>
      <a class="product-card" href="/products#grocery">
        <span class="product-icon">🥩</span>
        <h3>Halal Meats</h3>
        <p>Boneless chicken, chicken legs, whole chicken, and goat meat — all halal, cleaned and cut in-house, and kept frozen fresh.</p>
      </a>
      <a class="product-card" href="/products#grocery">
        <span class="product-icon">🫓</span>
        <h3>Injera & Breads</h3>
        <p>Fresh Ethiopian injera, frozen roti, naan, and pita — ready for your table.</p>
      </a>
      <a class="product-card" href="/products#grocery">
        <span class="product-icon">🥬</span>
        <h3>Fresh Produce & Fruit</h3>
        <p>Fresh vegetables, fruits, herbs, and specialty produce you won't find at the chain stores.</p>
      </a>
      <a class="product-card" href="/products#grocery">
        <span class="product-icon">❄️</span>
        <h3>Frozen & Pantry</h3>
        <p>Frozen meals, chutneys, pickles, sauces, falooda ice cream — your whole kitchen, stocked.</p>
      </a>
    </div>
  </section>

  <!-- Floating Delivery Widget -->
<div class="delivery-float">
  <a href="https://www.ubereats.com/store/international-groceries-4203-walnut-st/Qt-hin37VFSER2nNLpXjMw" target="_blank" rel="noopener noreferrer" class="float-btn uber">
    <span class="uber-dot"></span> Uber Eats
  </a>
  <a href="https://postmates.com/store/international-groceries-4203-walnut-st/Qt-hin37VFSER2nNLpXjMw" target="_blank" rel="noopener noreferrer" class="float-btn postmates">
    <span class="postmates-icon">⊕</span> Postmates
  </a>
</div>

</Layout>

<style>

 /* FLOATING DELIVERY WIDGET */
.delivery-float {
  position: fixed;
  right: 0;
  bottom: 5%;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  z-index: 1000;
}

.float-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.4rem 0.7rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  text-decoration: none;
  writing-mode: vertical-rl;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: -4px 0 16px rgba(0, 0, 0, 0.12);
}

.float-btn:hover {
  transform: translateX(-4px);
  box-shadow: -6px 0 24px rgba(0, 0, 0, 0.2);
}

.float-btn.uber {
  background: #fff;
  color: #1a1a1a;
  border-radius: 0.35rem 0 0 0.35rem;
}

.float-btn .uber-dot {
  width: 8px;
  height: 8px;
  background: #1a1a1a;
  border-radius: 50%;
  display: inline-block;
}

.float-btn.postmates {
  background: #FF5F00;
  color: #fff;
  border-radius: 0.35rem 0 0 0.35rem;
}

.float-btn .postmates-icon {
  font-size: 0.9rem;
  font-weight: 700;
}

	.samosa-photo img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	border-radius: 0.5rem;
	}
 
.hero {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5rem 3rem 2rem;
  position: relative;
  overflow: hidden;
}

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 168, 56, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -10%;
    left: -5%;
    width: 40vw;
    height: 40vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(194, 54, 22, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: clamp(3.2rem, 7.5vw, 7rem);
    line-height: 0.93;
    color: var(--dark);
    letter-spacing: -0.03em;
    max-width: 850px;
    animation: fadeSlideUp 0.8s 0.1s ease both;
    position: relative;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--chili);
  }

  .hero-sub {
    margin-top: 2rem;
    font-size: 1.12rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 460px;
    animation: fadeSlideUp 0.8s 0.25s ease both;
    position: relative;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 2rem;
    padding: 0.9rem 1.8rem;
    background: var(--chili);
    color: var(--cream);
    font-weight: 600;
    font-size: 0.88rem;
    border-radius: 0.4rem;
    text-decoration: none;
    transition: all 0.3s;
    animation: fadeSlideUp 0.8s 0.35s ease both;
    position: relative;
    letter-spacing: 0.02em;
  }

  .hero-cta:hover {
    background: var(--chili-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(194, 54, 22, 0.25);
  }

  .hero-details {
    display: flex;
    gap: 3rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
    animation: fadeSlideUp 0.8s 0.45s ease both;
    position: relative;
  }

  .hero-detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .hero-detail-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .hero-detail-link {
  text-decoration: none;
  color: var(--dark);
  transition: color 0.2s ease;
  }

  .hero-detail-link:hover {
    color: var(--chili);
  }

  .hero-detail-value {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--dark);
  }

  /* STATS STRIP */
  .intro-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .intro-strip-item {
    padding: 2.5rem 3rem;
    text-align: center;
    border-right: 1px solid var(--border-light);
  }

  .intro-strip-item:last-child { border-right: none; }

  .intro-strip-item .number {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--chili);
    line-height: 1;
  }

  .intro-strip-item .label {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  /* SAMOSA SPOTLIGHT */
  .samosa-spotlight {
    background: var(--dark);
    color: var(--cream);
    padding: 6rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .samosa-spotlight::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(194, 54, 22, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(232, 168, 56, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .samosa-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
  }

  .samosa-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .samosa-content h2 em {
    font-style: italic;
    color: var(--saffron);
  }

  .samosa-content p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(253, 246, 236, 0.65);
    max-width: 460px;
  }

  .samosa-quote {
    margin-top: 2rem;
    padding: 1.5rem;
    border-left: 3px solid var(--saffron);
    background: rgba(255,255,255,0.04);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .samosa-quote p {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: rgba(253, 246, 236, 0.85) !important;
    line-height: 1.6;
  }

  .samosa-quote cite {
    display: block;
    margin-top: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-style: normal;
    font-size: 0.75rem;
    color: var(--saffron);
    letter-spacing: 0.05em;
  }

	.samosa-photo {
	aspect-ratio: 1;
	background: var(--dark-warm);
	border-radius: 0.5rem;
	border: 1px solid rgba(255,255,255,0.06);
	overflow: hidden;
	}

	.samosa-photo img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	}

  /* PRODUCT PREVIEW */
  .products-preview {
    padding: 6rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .products-preview .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .products-preview .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 900;
    color: var(--dark);
    letter-spacing: -0.02em;
  }

  .see-all {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--chili);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: opacity 0.3s;
    flex-shrink: 0;
  }

  .see-all:hover { opacity: 0.7; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .product-card {
    padding: 2.2rem 1.8rem;
    background: var(--warm-white);
    border: 1px solid var(--border-light);
    border-radius: 0.5rem;
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  .product-card:hover {
    border-color: var(--saffron);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(26, 18, 8, 0.08);
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--saffron);
    transform: scaleX(0);
    transition: transform 0.35s ease;
  }

  .product-card:hover::before { transform: scaleX(1); }

  .product-icon {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    display: block;
  }

  .product-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }

  .product-card p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* CATERING CTA */
  .catering-cta-section {
    padding: 1rem 3rem 4rem;
    margin: 0 auto;
    max-width: 1200px;
  }

  .catering-cta-box {
    background: linear-gradient(135deg, var(--chili) 0%, var(--chili-dark) 100%);
    border-radius: 1rem;
    padding: 4.5rem 4rem;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    align-items: center;
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .catering-cta-box::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .catering-cta-content { position: relative; }

  .catering-cta-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .catering-cta-content p {
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.8rem;
    background: var(--cream);
    color: var(--chili);
    font-weight: 600;
    font-size: 0.88rem;
    border-radius: 0.4rem;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  .catering-cta-photo {
    aspect-ratio: 4/3;
    background: rgba(0,0,0,0.15);
    border-radius: 0.5rem;
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hero { padding: 4rem 1.5rem 3rem; min-height: 80vh; }
    .hero h1 { font-size: 2.8rem; }
    .hero-details { flex-direction: column; gap: 1.5rem; }
    .intro-strip { grid-template-columns: 1fr; }
    .intro-strip-item { border-right: none; border-bottom: 1px solid var(--border-light); }
    .intro-strip-item:last-child { border-bottom: none; }
    .samosa-inner { grid-template-columns: 1fr; }
    .samosa-photo { aspect-ratio: 16/10; }
    .product-grid { grid-template-columns: 1fr; }
    .products-preview { padding: 4rem 1.5rem; }
    .products-preview .section-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .catering-cta-section { padding: 3rem 1.5rem; }
    .catering-cta-box { grid-template-columns: 1fr; padding: 3rem 2rem; }

    .delivery-float {
        top: auto;
        bottom: 0;
        right: 0;
        transform: none;
        flex-direction: row;
        width: 100%;
      }

      .float-btn {
        writing-mode: horizontal-tb;
        flex: 1;
        justify-content: center;
        border-radius: 0;
        padding: 0.6rem 1rem;
        font-size: 0.75rem;
        box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.12);
      }

      .float-btn:hover {
        transform: none;
      }
  }
</style>